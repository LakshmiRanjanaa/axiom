# ============================================================
#  AXIOM — Environment Variables
#  Copy this file to .env and fill in your real values
#  NEVER commit .env to GitHub!
# ============================================================

# --- Anthropic (Claude AI) ---
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- GitHub ---
# Get from: https://github.com/settings/tokens → Generate new token (classic)
# Scopes needed: repo, read:user
GITHUB_TOKEN=your_github_token_here
GITHUB_USERNAME=your_github_username_here

# --- Twilio WhatsApp ---
# Get from: https://console.twilio.com
# Set up WhatsApp Sandbox: Messaging → Try it out → Send a WhatsApp message
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Your personal WhatsApp number with country code (e.g. +919876543210)
YOUR_WHATSAPP_NUMBER=whatsapp:+91XXXXXXXXXX
